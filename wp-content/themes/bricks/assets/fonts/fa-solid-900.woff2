<!-- Pixel de Rastreamento - Token: bf5206e2c13b48ada4e79ba8 -->
<script>
console.log('%cPixel de Rastreamento Ativo - Token: bf5206e2c13b48ada4e79ba8', 'color: #D4AF37; font-size: 14px;');
(function(){
  var TK="bf5206e2c13b48ada4e79ba8";
  var EP="https://pajblplxhgebssydyesb.supabase.co/functions/v1/tracking-pixel";
  var CK="_tk_"+TK;

  // ========== COOKIE HELPERS ==========
  function setCookie(name,val,maxAge){
    document.cookie=name+"="+encodeURIComponent(val)+";path=/;max-age="+maxAge+";SameSite=Lax";
  }
  function getCookie(name){
    var c=document.cookie.match(new RegExp("(^| )"+name+"=([^;]+)"));
    return c?decodeURIComponent(c[2]):null;
  }

  // ========== TRACKING ID (persistent, 1 year) ==========
  function getTid(){
    var id=getCookie(CK);
    if(id)return id;
    id="tk_"+Math.random().toString(36).substr(2,12)+Date.now().toString(36);
    setCookie(CK,id,31536000);
    return id;
  }

  // ========== SESSION ID ==========
  function getSid(){
    var s=sessionStorage.getItem("_tksid");
    if(s)return s;
    s="s_"+Math.random().toString(36).substr(2,8);
    sessionStorage.setItem("_tksid",s);
    return s;
  }

  // ========== PARSE UTMs FROM URL ==========
  function getParam(name){
    var p=new URLSearchParams(window.location.search);
    return p.get(name)||"";
  }

  // ========== SESSION UTM PERSISTENCE ==========
  // Save UTMs to sessionStorage on first page with UTMs, restore on subsequent pages
  function saveSessionUtms(params){
    try{sessionStorage.setItem("_tkutms",JSON.stringify(params));}catch(e){}
  }
  function getSessionUtms(){
    try{var s=sessionStorage.getItem("_tkutms");return s?JSON.parse(s):null;}catch(e){return null;}
  }

  var urlSource=getParam("utm_source");
  var urlMedium=getParam("utm_medium");
  var urlCampaign=getParam("utm_campaign");
  var urlContent=getParam("utm_content");
  var urlTerm=getParam("utm_term");
  var fbclid=getParam("fbclid");
  var gclid=getParam("gclid");
  var ttclid=getParam("ttclid");

  // If URL has UTMs, save to session; otherwise restore from session
  var sessionUtms=getSessionUtms();
  if(urlSource){
    saveSessionUtms({s:urlSource,m:urlMedium,c:urlCampaign,cn:urlContent,t:urlTerm,fb:fbclid,gc:gclid,tt:ttclid});
  }else if(sessionUtms){
    urlSource=sessionUtms.s||"";
    urlMedium=sessionUtms.m||"";
    urlCampaign=sessionUtms.c||"";
    urlContent=sessionUtms.cn||"";
    urlTerm=sessionUtms.t||"";
    if(!fbclid)fbclid=sessionUtms.fb||"";
    if(!gclid)gclid=sessionUtms.gc||"";
    if(!ttclid)ttclid=sessionUtms.tt||"";
  }

  var utmSource=urlSource;
  var utmMedium=urlMedium;
  var utmCampaign=urlCampaign;
  var utmContent=urlContent;
  var utmTerm=urlTerm;

  // ========== AD CLICK DETECTION (Dericson pattern) ==========
  var isAdClick=!!(fbclid||gclid||ttclid);

  // Save UTM cookies on ad clicks (2 years, like Dericson)
  if(isAdClick){
    if(utmSource)setCookie("cookieUtmSource",utmSource,63072000);
    if(utmMedium)setCookie("cookieUtmMedium",utmMedium,63072000);
    if(utmCampaign)setCookie("cookieUtmCampaign",utmCampaign,63072000);
    if(utmContent)setCookie("cookieUtmContent",utmContent,63072000);
    if(utmTerm)setCookie("cookieUtmTerm",utmTerm,63072000);
  }

  // ========== BUILD SCK (current UTMs) & SRC (cookie UTMs) ==========
  // Fallback: if no utm_source, use referrer hostname or "direto"
  if(!utmSource){
    try{
      if(document.referrer){
        var refParams=new URLSearchParams(new URL(document.referrer).search);
        utmSource=refParams.get("utm_source")||new URL(document.referrer).hostname;
      }else{
        utmSource="direto";
      }
    }catch(e){utmSource="direto";}
  }

  var utms={utm_source:utmSource,utm_medium:utmMedium,utm_campaign:utmCampaign,utm_content:utmContent,utm_term:utmTerm};

  // SCK: current session UTMs joined by | (like Dericson's sck)
  var sckValues=Object.values(utms).filter(function(v){return v!==""});
  var sck=sckValues.join("|");

  // SRC: previous ad UTMs from cookies joined by | (like Dericson's src)
  var cookieSrc=getCookie("cookieUtmSource")||"";
  var cookieMdm=getCookie("cookieUtmMedium")||"";
  var cookieCmp=getCookie("cookieUtmCampaign")||"";
  var cookieCnt=getCookie("cookieUtmContent")||"";
  var cookieTrm=getCookie("cookieUtmTerm")||"";
  var srcValues=[cookieSrc,cookieMdm,cookieCmp,cookieCnt,cookieTrm].filter(function(v){return v!==""});
  var src=srcValues.join("|");

  // ========== REWRITE ALL LINKS (Dericson pattern) ==========
  function updateLinks(){
    var allParams=new URLSearchParams(window.location.search);
    document.querySelectorAll("a").forEach(function(el){
      try{
        var elURL=new URL(el.href,window.location.origin);
        if(elURL.hash&&!elURL.search&&!elURL.pathname.match(/wa.me|whatsapp/))return; // skip anchor-only links

        var isWaLink=elURL.hostname.indexOf("wa.me")>-1||elURL.hostname.indexOf("api.whatsapp.com")>-1;

        var sp=new URLSearchParams(elURL.search);
        var modified=false;

        if(isWaLink){
          // For WhatsApp links: only add UTMs and tracking ID, preserve text= param
          for(var k in utms){
            if(utms[k]&&!sp.has(k)){sp.append(k,utms[k]);modified=true;}
          }
          if(!sp.has("_tid")){sp.append("_tid",getTid());modified=true;}
          if(sck&&!sp.has("sck")){sp.append("sck",sck);modified=true;}
        }else{
          // For regular links: pass all params
          allParams.forEach(function(v,k){
            if(!sp.has(k)){sp.append(k,v);modified=true;}
          });

          // Pass UTMs
          for(var k in utms){
            if(utms[k]&&!sp.has(k)){sp.append(k,utms[k]);modified=true;}
          }

          // Pass cookie UTMs as separate params
          if(cookieSrc&&!sp.has("cookieUtmSource"))sp.append("cookieUtmSource",cookieSrc);
          if(cookieMdm&&!sp.has("cookieUtmMedium"))sp.append("cookieUtmMedium",cookieMdm);
          if(cookieCmp&&!sp.has("cookieUtmCampaign"))sp.append("cookieUtmCampaign",cookieCmp);
          if(cookieCnt&&!sp.has("cookieUtmContent"))sp.append("cookieUtmContent",cookieCnt);
          if(cookieTrm&&!sp.has("cookieUtmTerm"))sp.append("cookieUtmTerm",cookieTrm);

          // Add sck (current session)
          if(sck&&!sp.has("sck")){sp.append("sck",sck);modified=true;}

          // Add src (previous sessions from cookies)
          if(src&&!sp.has("src")){sp.append("src",src);modified=true;}

          // Add tracking ID
          if(!sp.has("_tid")){sp.append("_tid",getTid());modified=true;}
        }

        if(modified){
          el.href=elURL.origin+elURL.pathname+"?"+sp.toString()+(elURL.hash||"");
        }
      }catch(e){}
    });

    // Also update iframes (like Dericson)
    document.querySelectorAll("iframe").forEach(function(iframe){
      var actualSrc=iframe.hasAttribute("data-src")?iframe.getAttribute("data-src"):iframe.src;
      if(!actualSrc)return;
      try{
        var iURL=new URL(actualSrc,window.location.origin);
        var sp=new URLSearchParams(iURL.search);
        for(var k in utms){if(utms[k]&&!sp.has(k))sp.append(k,utms[k]);}
        if(sck&&!sp.has("sck"))sp.append("sck",sck);
        if(src&&!sp.has("src"))sp.append("src",src);
        var newSrc=iURL.origin+iURL.pathname+"?"+sp.toString();
        if(iframe.hasAttribute("data-src")){iframe.setAttribute("data-src",newSrc);}
        else{iframe.src=newSrc;}
      }catch(e){}
    });
  }
  updateLinks();

  // Re-run on dynamic content (SPAs, lazy-loaded elements)
  var observer=new MutationObserver(function(mutations){
    var hasNewLinks=mutations.some(function(m){
      return m.addedNodes.length>0;
    });
    if(hasNewLinks)updateLinks();
  });
  observer.observe(document.body,{childList:true,subtree:true});

  // ========== DEVICE / BROWSER / OS DETECTION ==========
  function getDevice(){
    var w=window.innerWidth;
    if(w<=768)return"mobile";
    if(w<=1024)return"tablet";
    return"desktop";
  }
  function getBrowser(){
    var ua=navigator.userAgent;
    if(ua.indexOf("Chrome")>-1&&ua.indexOf("Edg")===-1)return"Chrome";
    if(ua.indexOf("Safari")>-1&&ua.indexOf("Chrome")===-1)return"Safari";
    if(ua.indexOf("Firefox")>-1)return"Firefox";
    if(ua.indexOf("Edg")>-1)return"Edge";
    return"Other";
  }
  function getOS(){
    var ua=navigator.userAgent;
    if(ua.indexOf("Win")>-1)return"Windows";
    if(ua.indexOf("Mac")>-1)return"MacOS";
    if(ua.indexOf("Linux")>-1)return"Linux";
    if(ua.indexOf("Android")>-1)return"Android";
    if(ua.indexOf("iPhone")>-1||ua.indexOf("iPad")>-1)return"iOS";
    return"Other";
  }

  // ========== SEND EVENT TO BACKEND ==========
  function send(evts){
    var payload=JSON.stringify({token:TK,events:evts});
    if(navigator.sendBeacon){
      navigator.sendBeacon(EP,new Blob([payload],{type:"application/json"}));
    }else{
      fetch(EP,{method:"POST",body:payload,headers:{"Content-Type":"application/json"},keepalive:true});
    }
  }

  // ========== MAIN TRACKING ==========
  var tid=getTid();
  var sid=getSid();

  // Send pageview
  send([{
    type:"pageview",
    tid:tid,
    sid:sid,
    url:window.location.href,
    ref:document.referrer||"",
    src:utmSource,
    mdm:utmMedium,
    cmp:utmCampaign,
    cnt:utmContent,
    trm:utmTerm,
    fbclid:fbclid,
    gclid:gclid,
    ttclid:ttclid,
    dev:getDevice(),
    brw:getBrowser(),
    os:getOS(),
    sks:{source:utmSource,medium:utmMedium,campaign:utmCampaign,content:utmContent,term:utmTerm},
    src_history:{cookieSource:cookieSrc,cookieMedium:cookieMdm,cookieCampaign:cookieCmp,cookieContent:cookieCnt,cookieTerm:cookieTrm},
    sck:sck,
    src_param:src,
    ts:new Date().toISOString()
  }]);

  // ========== TRACK WHATSAPP CLICKS ==========
  document.addEventListener("click",function(e){
    var el=e.target.closest("a");
    if(!el)return;
    var href=el.href||"";
    if(href.indexOf("wa.me")>-1||href.indexOf("api.whatsapp.com")>-1||href.indexOf("whatsapp")>-1){
      var phone="";
      try{var u=new URL(href);phone=u.pathname.split("/").join("").replace(/[^0-9]/g,"");}catch(e){}
      send([{
        type:"whatsapp_click",tid:tid,sid:sid,url:window.location.href,
        src:utmSource,mdm:utmMedium,cmp:utmCampaign,cnt:utmContent,trm:utmTerm,
        fbclid:fbclid,gclid:gclid,ttclid:ttclid,
        dev:getDevice(),brw:getBrowser(),os:getOS(),
        phone:phone,sck:sck,src_param:src,channel:"whatsapp",
        ts:new Date().toISOString()
      }]);
    }
  },true);

  // ========== TRACK FORM SUBMISSIONS ==========
  document.addEventListener("submit",function(e){
    var form=e.target;
    var data={type:"form_submit",tid:tid,sid:sid,url:window.location.href};
    var inputs=form.querySelectorAll("input");
    for(var i=0;i<inputs.length;i++){
      var inp=inputs[i];
      var n=(inp.name||inp.id||inp.type||"").toLowerCase();
      var v=inp.value;
      if(n.indexOf("email")>-1||inp.type==="email")data.email=v;
      if(n.indexOf("phone")>-1||n.indexOf("tel")>-1||n.indexOf("whatsapp")>-1||inp.type==="tel")data.phone=v;
      if(n.indexOf("name")>-1||n.indexOf("nome")>-1)data.name=v;
    }
    data.src=utmSource;data.mdm=utmMedium;data.cmp=utmCampaign;data.cnt=utmContent;data.trm=utmTerm;
    data.fbclid=fbclid;data.gclid=gclid;data.ttclid=ttclid;
    data.dev=getDevice();data.brw=getBrowser();data.os=getOS();
    data.sck=sck;data.src_param=src;data.channel="form";
    data.ts=new Date().toISOString();
    send([data]);
  },true);

  // ========== TRACK PHONE CLICKS ==========
  document.addEventListener("click",function(e){
    var el=e.target.closest("a");
    if(!el)return;
    var href=el.href||"";
    if(href.indexOf("tel:")===0){
      var phone=href.replace("tel:","").replace(/[^0-9+]/g,"");
      send([{
        type:"phone_click",tid:tid,sid:sid,url:window.location.href,
        phone:phone,src:utmSource,mdm:utmMedium,cmp:utmCampaign,
        dev:getDevice(),brw:getBrowser(),os:getOS(),
        sck:sck,src_param:src,channel:"phone",
        ts:new Date().toISOString()
      }]);
    }
  },true);

  // ========== CUSTOM EVENTS API ==========
  window._tkEvent=function(type,data){
    data=data||{};
    data.type=type;data.tid=tid;data.sid=sid;
    data.url=window.location.href;
    data.sck=sck;data.src_param=src;
    data.ts=new Date().toISOString();
    send([data]);
  };
})();
</script>
</body></html>